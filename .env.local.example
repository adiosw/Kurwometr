# ============================================================
# KURWOMAT — Zmienne Środowiskowe
# Skopiuj do .env.local i uzupełnij WSZYSTKIE wartości
# ============================================================

# ── SUPABASE ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://TWOJ_PROJEKT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service Role Key — TYLKO server-side! Nigdy nie wstawiaj do komponentów klienta!
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── STRIPE ────────────────────────────────────────────────
# Klucze z https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...

# Webhook secret z Stripe Dashboard > Webhooks > Endpoint
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs — utwórz w Stripe Dashboard > Products
# Premium miesięczny: 9.99 PLN recurring
STRIPE_PRICE_MONTHLY=price_...
# Premium lifetime: 49.99 PLN one-time
STRIPE_PRICE_LIFETIME=price_...

# ── APP ───────────────────────────────────────────────────
NEXT_PUBLIC_URL=https://kurwomat.pl

# ── PWA PUSH (VAPID) ──────────────────────────────────────
# Wygeneruj: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=BNFoxxxxxx...
VAPID_PRIVATE_KEY=xxxxxx...
VAPID_EMAIL=mailto:admin@kurwomat.pl

# ── CRON SECRET ───────────────────────────────────────────
# Losowy string min 32 znaków — zabezpiecza endpoint /api/push-send
CRON_SECRET=twoj-bardzo-tajny-klucz-min-32-znaki

# ── SEO ───────────────────────────────────────────────────
# Z Google Search Console > Weryfikacja strony > HTML tag
GOOGLE_SITE_VERIFICATION=abc123...

# ── GOOGLE ANALYTICS 4 ────────────────────────────────────
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ── OPCJONALNE: UPSTASH REDIS (Rate Limiting prod) ────────
# Dla lepszego rate limitingu na produkcji (zamiast in-memory)
# UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=xxx
